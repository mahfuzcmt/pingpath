# Copy to .env and adjust for your setup. Values are inlined at build time
# via Expo's EXPO_PUBLIC_ convention.

# REST API base (Spring backend, context-path /api/v1).
#   Android emulator → host machine is 10.0.2.2
#   iOS simulator    → localhost
#   Physical device  → your machine's LAN IP, e.g. http://192.168.0.10:8080/api/v1
EXPO_PUBLIC_API_BASE=http://10.0.2.2:8080/api/v1

# STOMP WebSocket endpoint (same host, path /ws).
EXPO_PUBLIC_WS_BASE=ws://10.0.2.2:8080/ws

# Mapbox public token (same one the web dashboard uses).
EXPO_PUBLIC_MAPBOX_TOKEN=
