# Browser-side base URL for the Next.js BFF proxy.
# All REST calls go to /api/proxy/* on the same origin so that we can hold the
# JWT in an HTTP-only cookie and never expose it to JS (CLAUDE.md §14).
NEXT_PUBLIC_API_BASE=/api/proxy

# Browser-side WebSocket endpoint. Connects directly to the backend; the
# backend STOMP CONNECT frame carries the JWT in its Authorization header.
# In dev: ws://localhost:8080/ws — in prod: wss://api.pingpath.com/ws
NEXT_PUBLIC_WS_BASE=ws://localhost:8080/ws

# Server-side only: where the Next.js proxy forwards requests. Never exposed.
BACKEND_BASE=http://localhost:8080

# Mapbox public token. Restrict by URL referrer in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Cookie name + max-age (seconds) for the session JWT.
SESSION_COOKIE_NAME=pp_session
SESSION_COOKIE_MAX_AGE=86400
