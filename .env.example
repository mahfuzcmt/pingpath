# PingPath — local development environment
# Copy to .env and fill real values. Never commit .env.

# ----- Database (Postgres + PostGIS) -----
POSTGRES_DB=pingpath
POSTGRES_USER=pingpath
POSTGRES_PASSWORD=pingpath_dev

# ----- Backend (Spring Boot) -----
# JDBC URL the backend uses to reach Postgres from inside docker compose
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/pingpath
SPRING_DATASOURCE_USERNAME=pingpath
SPRING_DATASOURCE_PASSWORD=pingpath_dev

SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# ----- JWT (CLAUDE.md §14.1) -----
# 32+ random bytes, base64-encoded. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-32-byte-random-secret
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ----- Netty TCP server (GT06 ingest) -----
NETTY_TCP_PORT=5023

# ----- Mapbox (frontend, CLAUDE.md §2) -----
NEXT_PUBLIC_MAPBOX_TOKEN=

# ----- bKash Tokenized Checkout (CLAUDE.md §12.1) -----
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_CALLBACK_URL=http://localhost:8080/api/v1/billing/webhooks/bkash

# ----- SSL Wireless SMS (CLAUDE.md §12.2) -----
SSL_SMS_API_TOKEN=
SSL_SMS_SENDER_ID=PINGPATH

# ----- Firebase Cloud Messaging (push, Phase 5) -----
FCM_SERVICE_ACCOUNT_JSON=
